
all: swidtags_plugin

swidtags_plugin: swidtags.so

swidtags.so: swidtags_plugin.cpp
	g++ -g -fPIC -std=gnu++20 -shared $(shell pkgconf --cflags --libs libdnf5 libxml++-2.6) -Wcast-align -Wno-uninitialized -Wredundant-decls -Wwrite-strings -Wformat-nonliteral -Wmissing-format-attribute -Wsign-compare -Wtype-limits -Wuninitialized -Wall -Wl,--as-needed -o swidtags.so swidtags_plugin.cpp

test:
	./test.sh

install: swidtags.so
	cp swidtags.so /usr/lib*/libdnf5/plugins/

clean:
	rm -rf $(shell cat .gitignore)

VERSION := $(shell rpm -q --qf 'libdnf-plugin-swidtags-%{version}\n' --specfile *.spec 2> /dev/null | head -1)

srpm:
	tar c --transform="s#^#$(VERSION)/#" --exclude-from=.dockerignore -vzf $(VERSION).tar.gz *
	rpmbuild -D '_srcrpmdir .' -D '_sourcedir .' -bs *.spec

.PHONY: swidtags_plugin install test clean

